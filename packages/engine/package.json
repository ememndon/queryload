{
  "name": "@queryload/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts -- --mode desktop",
    "build": "tsc -b && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "1.28.0",
    "@lancedb/lancedb": "0.31.0",
    "@node-rs/argon2": "2.0.2",
    "@queryload/shared": "*",
    "adm-zip": "0.6.0",
    "better-sqlite3-multiple-ciphers": "12.11.1",
    "bonjour-service": "1.4.3",
    "chokidar": "5.0.0",
    "mailparser": "3.9.14",
    "mammoth": "1.12.0",
    "mupdf": "1.28.0",
    "pino": "9.6.0",
    "pst-extractor": "1.12.0",
    "selfsigned": "2.4.1"
  },
  "optionalDependencies": {
    "node-windows": "1.0.0-beta.8"
  },
  "devDependencies": {
    "@types/adm-zip": "0.5.8",
    "@types/mailparser": "3.4.6"
  }
}
